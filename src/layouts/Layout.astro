---
import { SEO } from "astro-seo";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const resolvedImageWithDomain = new URL("/opengraph.jpg", Astro.site).toString();
const { title } = Astro.props;

const makeTitle = title
  ? title + " | The Yellow Bait House"
  : "The Yellow Bait House | Key Largo's Bait, Tackle & Seafood Market";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={makeTitle}
      description="The Yellow Bait House — Key Largo's favorite bait shop, tackle store, and seafood market since day one. Live bait, rod repairs, rentals, fresh local seafood & food menu. Open daily at 6AM."
      canonical={canonicalURL}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: `The Yellow Bait House | Key Largo, FL`,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "The Yellow Bait House in Key Largo, Florida Keys",
        },
      }}
    />
  </head>
  <body class="bg-yellow-50">
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
