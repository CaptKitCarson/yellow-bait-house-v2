---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import storeImg from "@/assets/outside_store2.webp";
import mulletImg from "@/assets/mullet.jpg";
import ballyhooImg from "@/assets/ballyhoo.jpg";
import storeInteriorImg from "@/assets/store.jpg";
---

<Layout title="Bait & Tackle">
  <div class="relative">
    <Image src={storeImg} alt="The Yellow Bait House exterior" class="absolute inset-0 w-full h-full object-cover" width={1600} height={600} />
    <div class="absolute inset-0 bg-yellow-800/70"></div>
    <div class="relative">
      <Container>
        <div class="py-16 text-center text-white">
          <h1 class="text-4xl lg:text-5xl font-bold mb-4">Bait & Tackle</h1>
          <p class="text-xl text-yellow-200 max-w-2xl mx-auto">
            Everything you need to get on the water. Live bait, frozen bait, full tackle shop,
            rod repairs, and gear rentals.
          </p>
        </div>
      </Container>
    </div>
  </div>

  <div class="bg-yellow-100 border-b border-yellow-200">
    <Container>
      <p class="py-3 text-center text-yellow-800 font-medium">
        💰 Prices vary with availability. Call <a href="tel:+13054510921" class="underline font-bold">(305) 451-0921</a> for current pricing.
      </p>
    </Container>
  </div>

  <Container>
    <div class="py-12 lg:py-20">
      <!-- Live Bait with image -->
      <section class="mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">🦐</span>
              <h2 class="text-3xl font-bold text-yellow-700">Live Bait</h2>
            </div>
            <p class="text-stone-600 mb-6">
              Quality live bait housed in aerated tanks. Staff will show you around — even
              give your kids a tour of the tanks.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { name: "Live Shrimp", note: "The bread and butter of Keys fishing" },
                { name: "Live Pilchards", note: "Silver bullets — irresistible to game fish" },
                { name: "Live Pinfish", note: "Bottom fishing & reef trips" },
                { name: "Live Mullet", note: "Snook, tarpon & big game" },
                { name: "Live Crabs", note: "Permit & tarpon bait" },
                { name: "Live Ballyhoo", note: "When available — call ahead" },
              ].map(item => (
                <div class="bg-white border border-stone-200 rounded-xl p-5 hover:border-yellow-400 transition-colors">
                  <h3 class="font-bold text-yellow-700 text-lg">{item.name}</h3>
                  <p class="text-stone-500 text-sm mt-1">{item.note}</p>
                </div>
              ))}
            </div>
          </div>
          <div class="hidden lg:block">
            <Image src={mulletImg} alt="Fresh mullet on ice" class="rounded-2xl w-full object-cover shadow-md" width={500} height={600} />
          </div>
        </div>
      </section>

      <!-- Frozen Bait with image -->
      <section class="mb-16">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
          <div class="hidden lg:block">
            <Image src={ballyhooImg} alt="Fresh ballyhoo on ice" class="rounded-2xl w-full object-cover shadow-md" width={500} height={600} />
          </div>
          <div class="lg:col-span-2">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">🧊</span>
              <h2 class="text-3xl font-bold text-yellow-700">Frozen Bait</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { name: "Frozen Shrimp", note: "Always available" },
                { name: "Ballyhoo", note: "Whole & rigged" },
                { name: "Squid", note: "Strips & whole" },
                { name: "Chum Blocks", note: "For chumming the reef" },
                { name: "Cut Bait", note: "Ready to fish" },
                { name: "Cigar Minnows", note: "Trolling & bottom fishing" },
              ].map(item => (
                <div class="bg-white border border-stone-200 rounded-xl p-5 hover:border-yellow-400 transition-colors">
                  <h3 class="font-bold text-yellow-700 text-lg">{item.name}</h3>
                  <p class="text-stone-500 text-sm mt-1">{item.note}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Tackle & Services with image -->
      <section class="mb-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <span class="text-3xl">🎣</span>
              <h2 class="text-3xl font-bold text-yellow-700">Tackle & Services</h2>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-6">
              {["Hooks & Rigs", "Weights & Sinkers", "Leader Material", "Fishing Line", "Lures & Jigs", "Nets & Gaffs", "Coolers & Buckets", "Souvenirs & Gifts"].map(item => (
                <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-3 text-center">
                  <span class="font-semibold text-yellow-800 text-sm">{item}</span>
                </div>
              ))}
            </div>
            <div class="space-y-4">
              <div class="bg-white border border-stone-200 rounded-xl p-5">
                <h4 class="font-bold text-yellow-700 flex items-center gap-2">🔧 Rod Repairs</h4>
                <p class="text-stone-500 text-sm mt-1">Broken tip? Snapped guide? We fix rods on-site.</p>
              </div>
              <div class="bg-white border border-stone-200 rounded-xl p-5">
                <h4 class="font-bold text-yellow-700 flex items-center gap-2">🎣 Rod & Reel Rentals</h4>
                <p class="text-stone-500 text-sm mt-1">Don't own gear? Rent a full setup and fish the bridges or the reef.</p>
              </div>
            </div>
          </div>
          <div class="hidden md:block">
            <Image src={storeInteriorImg} alt="Inside The Yellow Bait House" class="rounded-2xl w-full object-cover shadow-md h-full" width={700} height={800} />
          </div>
        </div>
      </section>

      <div class="bg-yellow-600 text-white rounded-2xl p-8 lg:p-12 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold mb-3">Need Gear Advice?</h2>
        <p class="text-yellow-200 text-lg mb-6 max-w-xl mx-auto">
          Call us or stop by. We'll get you dialed in for whatever you're targeting.
        </p>
        <a href="tel:+13054510921" class="inline-block bg-white text-yellow-700 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-50 transition-colors">
          📞 (305) 451-0921
        </a>
      </div>
    </div>
  </Container>
</Layout>
