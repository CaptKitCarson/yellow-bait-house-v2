---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Seafood Market">
  <div class="bg-yellow-600 text-white">
    <Container>
      <div class="py-16 text-center">
        <h1 class="text-4xl lg:text-5xl font-bold mb-4">Seafood Market</h1>
        <p class="text-xl text-yellow-200 max-w-2xl mx-auto">
          Only locally caught fish. Best prices in the Keys.
          No imports, no middlemen — straight from Keys fishermen to your table.
        </p>
      </div>
    </Container>
  </div>

  <Container>
    <div class="py-12 lg:py-20">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-lg text-stone-600 leading-relaxed">
          Our seafood market only sells locally caught fish, so the selection changes
          with the catch. That's the point — it's always fresh, never frozen imports.
          Call <a href="tel:+13054510921" class="text-yellow-700 font-semibold underline">(305) 451-0921</a>
          for today's availability.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        <div class="bg-white border border-stone-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
          <div class="text-5xl mb-4">🦀</div>
          <h2 class="text-2xl font-bold text-yellow-700 mb-3">Stone Crab Claws</h2>
          <p class="text-stone-600 leading-relaxed mb-3">
            Fresh stone crab claws with our house-made mustard sauce. Customers drive from
            all over the Keys for these. Available in season.
          </p>
          <p class="text-sm text-amber-700 font-medium bg-amber-50 rounded-lg px-3 py-2 inline-block">
            🗓️ Season: Oct 15 – May 1
          </p>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
          <div class="text-5xl mb-4">🐟</div>
          <h2 class="text-2xl font-bold text-yellow-700 mb-3">Fresh Local Fish</h2>
          <p class="text-stone-600 leading-relaxed">
            Yellowtail snapper, hogfish, grouper, mahi — whatever the boats bring in.
            Selection is limited because it's all local, but the quality and price can't be beat.
          </p>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
          <div class="text-5xl mb-4">🦞</div>
          <h2 class="text-2xl font-bold text-yellow-700 mb-3">Florida Lobster</h2>
          <p class="text-stone-600 leading-relaxed mb-3">
            Fresh Florida spiny lobster when it's running. A Keys staple that you won't
            find cheaper anywhere else on the island.
          </p>
          <p class="text-sm text-amber-700 font-medium bg-amber-50 rounded-lg px-3 py-2 inline-block">
            🗓️ Season: Aug 6 – March 31
          </p>
        </div>

        <div class="bg-white border border-stone-200 rounded-2xl p-8 hover:shadow-md transition-shadow">
          <div class="text-5xl mb-4">🍤</div>
          <h2 class="text-2xl font-bold text-yellow-700 mb-3">Shrimp & More</h2>
          <p class="text-stone-600 leading-relaxed">
            Key West pink shrimp, smoked fish dip, and other local specialties.
            Perfect for a quick dinner or a cooler to take home.
          </p>
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-yellow-600 text-white rounded-2xl p-8 lg:p-12 text-center">
        <h2 class="text-2xl lg:text-3xl font-bold mb-3">What's Fresh Today?</h2>
        <p class="text-yellow-200 text-lg mb-6 max-w-xl mx-auto">
          Selection changes daily. Give us a call or follow us on Facebook for updates.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13054510921" class="inline-block bg-white text-yellow-700 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-50 transition-colors">
            📞 (305) 451-0921
          </a>
          <a href="https://www.facebook.com/p/The-Yellow-Bait-House-100057521618227/" target="_blank" class="inline-block border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition-colors">
            Follow on Facebook
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
