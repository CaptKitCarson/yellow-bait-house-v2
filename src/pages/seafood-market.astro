---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import lobstersImg from "@/assets/lobsters.jpg";
import muttonImg from "@/assets/mutton.jpg";
import cobiaImg from "@/assets/cobia.jpg";
import mangrovesImg from "@/assets/mangroves.jpg";
---

<Layout title="Seafood Market">
  <div class="relative h-64">
    <Image src={mangrovesImg} alt="Fresh catch on ice" class="absolute inset-0 w-full h-full object-cover" width={1600} height={400} />
    <div class="absolute inset-0 bg-gradient-to-r from-[#3D2E1C]/90 to-[#3D2E1C]/50 flex items-end">
      <Container>
        <div class="pb-8">
          <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Market</span>
          <h1 class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tight">Seafood Market</h1>
        </div>
      </Container>
    </div>
  </div>

  <Container>
    <div class="py-12 lg:py-16">
      <div class="max-w-3xl mb-12">
        <p class="text-lg text-stone-600 leading-relaxed">
          We only sell locally caught fish. Selection changes daily with the catch — 
          that's the whole point. Best prices in the Keys because we cut out the middleman.
          Call <a href="tel:+13054510921" class="text-[#C41E24] font-bold underline">(305) 451-0921</a>
          for what's fresh today.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
        <div class="group relative rounded-xl overflow-hidden h-80">
          <Image src={lobstersImg} alt="Fresh Florida spiny lobster on ice" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <h2 class="text-white text-2xl font-black uppercase">Florida Lobster</h2>
            <p class="text-stone-300 text-sm mt-1">Fresh spiny lobster — cheapest on the island</p>
            <span class="inline-block mt-2 text-[#F5C518] text-xs font-bold uppercase bg-black/40 px-2 py-1 rounded">Season: Aug 6 – Mar 31</span>
          </div>
        </div>

        <div class="group relative rounded-xl overflow-hidden h-80">
          <Image src={cobiaImg} alt="Fresh cobia" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <h2 class="text-white text-2xl font-black uppercase">Stone Crab Claws</h2>
            <p class="text-stone-300 text-sm mt-1">With our house-made mustard sauce</p>
            <span class="inline-block mt-2 text-[#F5C518] text-xs font-bold uppercase bg-black/40 px-2 py-1 rounded">Season: Oct 15 – May 1</span>
          </div>
        </div>

        <div class="group relative rounded-xl overflow-hidden h-80">
          <Image src={muttonImg} alt="Fresh mutton snapper" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <h2 class="text-white text-2xl font-black uppercase">Fresh Local Fish</h2>
            <p class="text-stone-300 text-sm mt-1">Yellowtail, mutton, hogfish, grouper, mahi — whatever the boats bring in</p>
          </div>
        </div>

        <div class="bg-[#3D2E1C] rounded-xl p-8 flex flex-col justify-center h-80">
          <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest mb-3">Also Available</span>
          <ul class="space-y-4 text-white">
            <li class="flex items-center gap-3"><span class="text-2xl">🍤</span> <span>Key West Pink Shrimp</span></li>
            <li class="flex items-center gap-3"><span class="text-2xl">🐟</span> <span>Smoked Fish Dip</span></li>
            <li class="flex items-center gap-3"><span class="text-2xl">🦀</span> <span>Stone Crab Mustard Sauce</span></li>
            <li class="flex items-center gap-3"><span class="text-2xl">🧊</span> <span>Seasonal Specials</span></li>
          </ul>
          <a href="https://www.facebook.com/p/The-Yellow-Bait-House-100057521618227/" target="_blank" class="mt-6 text-[#F5C518] font-bold text-sm uppercase hover:underline">
            Follow Facebook for daily updates →
          </a>
        </div>
      </div>

      <div class="bg-[#C41E24] text-white rounded-lg p-8 lg:p-12 text-center">
        <h2 class="text-2xl lg:text-3xl font-black uppercase mb-3">What's Fresh Today?</h2>
        <p class="text-red-200 text-lg mb-6">Selection changes daily. Give us a call.</p>
        <a href="tel:+13054510921" class="inline-block bg-white text-[#C41E24] px-8 py-4 rounded-md font-black text-lg hover:bg-stone-100 transition-colors">
          📞 305-451-0921
        </a>
      </div>
    </div>
  </Container>
</Layout>
