---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import storeImg from "@/assets/outside_store.webp";
import permitImg from "@/assets/permit.jpg";
import mahiImg from "@/assets/mahi.jpg";
---

<Layout title="About Us">
  <div class="relative h-64">
    <Image src={storeImg} alt="The Yellow Bait House storefront" class="absolute inset-0 w-full h-full object-cover" width={1600} height={400} />
    <div class="absolute inset-0 bg-gradient-to-r from-[#3D2E1C]/90 to-[#3D2E1C]/50 flex items-end">
      <Container>
        <div class="pb-8">
          <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">About</span>
          <h1 class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tight">The Yellow Bait House</h1>
        </div>
      </Container>
    </div>
  </div>

  <Container>
    <div class="py-12 lg:py-16">
      <!-- Story with images -->
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 mb-20">
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-black text-[#3D2E1C] uppercase tracking-tight mb-1">Our Story</h2>
          <div class="h-1 w-16 bg-[#C41E24] mb-6"></div>
          <p class="text-stone-600 leading-relaxed mb-6">
            The Yellow Bait House has been a fixture on US-1 in Key Largo for as long as most
            anglers can remember. That bright yellow building at Mile Marker 101 is the first
            stop for anyone heading out to fish the Upper Keys — and the last stop for anyone
            bringing home dinner.
          </p>
          <p class="text-stone-600 leading-relaxed mb-6">
            What started as a straightforward bait and tackle shop has grown into something
            bigger: a full seafood market selling only locally caught fish, a rod repair and
            rental shop, a souvenir stop, and now a food menu serving up fresh seafood dishes.
          </p>
          <p class="text-stone-600 leading-relaxed">
            But we haven't changed what matters. Our staff still knows every customer by name,
            still gives out free fishing advice, and still treats every kid who walks in like it's
            their first time seeing a live bait tank — because it might be.
          </p>
        </div>
        <div class="lg:col-span-2 space-y-4">
          <Image src={permitImg} alt="Angler with permit" class="rounded-lg shadow-lg w-full object-cover" width={500} height={350} />
          <Image src={mahiImg} alt="Mahi-mahi haul in Key Largo" class="rounded-lg shadow-lg w-full object-cover" width={500} height={350} />
        </div>
      </div>

      <!-- Stats -->
      <div class="bg-[#3D2E1C] rounded-lg p-8 lg:p-12 mb-20">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
          <div>
            <span class="text-[#F5C518] text-4xl font-black block">137+</span>
            <span class="text-white font-bold block mt-1">Customer Reviews</span>
            <span class="text-stone-400 text-sm">And counting</span>
          </div>
          <div>
            <span class="text-[#F5C518] text-4xl font-black block">7</span>
            <span class="text-white font-bold block mt-1">Days a Week</span>
            <span class="text-stone-400 text-sm">Open from 6AM</span>
          </div>
          <div>
            <span class="text-[#F5C518] text-4xl font-black block">100%</span>
            <span class="text-white font-bold block mt-1">Local Seafood</span>
            <span class="text-stone-400 text-sm">No imports, ever</span>
          </div>
        </div>
      </div>

      <!-- Everything Under One Roof -->
      <div class="mb-20">
        <h2 class="text-2xl font-black text-[#3D2E1C] uppercase tracking-tight mb-1">Everything Under One Roof</h2>
        <div class="h-1 w-16 bg-[#C41E24] mb-8"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {[
            { icon: "🦐", text: "Live bait — shrimp, pilchards, pinfish, mullet, crabs" },
            { icon: "🧊", text: "Frozen bait — ballyhoo, squid, chum blocks" },
            { icon: "🎣", text: "Full tackle shop — hooks, rigs, leader, line, lures" },
            { icon: "🔧", text: "Rod repairs — fixed on-site, same day" },
            { icon: "🎣", text: "Rod & reel rentals — fish today without buying gear" },
            { icon: "🦀", text: "Seafood market — stone crab, fresh fish, lobster, shrimp" },
            { icon: "🎁", text: "Souvenirs & gifts — take a piece of the Keys home" },
            { icon: "🧠", text: "Free fishing advice — where to go, what to use" },
          ].map(item => (
            <div class="flex gap-3 bg-white border-l-4 border-[#F5C518] p-4">
              <span class="text-xl shrink-0">{item.icon}</span>
              <p class="text-stone-600 text-sm">{item.text}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-[#C41E24] text-white rounded-lg p-8 lg:p-12 text-center">
        <h2 class="text-2xl font-black uppercase mb-3">Come See Us</h2>
        <p class="text-red-200 mb-6">Mile Marker 101. Can't miss the yellow building.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+13054510921" class="bg-white text-[#C41E24] px-8 py-4 rounded-md font-black text-lg hover:bg-stone-100 transition-colors">
            📞 305-451-0921
          </a>
          <a href="/find-us" class="border-2 border-white text-white px-8 py-4 rounded-md font-black text-lg hover:bg-white/10 transition-colors">
            📍 Get Directions
          </a>
        </div>
      </div>
    </div>
  </Container>
</Layout>
