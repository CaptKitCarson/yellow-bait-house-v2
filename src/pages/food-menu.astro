---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Food Menu">
  <div class="bg-[#3D2E1C]">
    <Container>
      <div class="py-12">
        <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Eat</span>
        <h1 class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tight">Food Menu</h1>
        <p class="text-stone-400 mt-3 max-w-lg">
          More than just a bait shop. Fresh seafood, island-inspired dishes, and cold drinks.
        </p>
      </div>
    </Container>
  </div>
  <div class="h-1 bg-[#C41E24]"></div>

  <Container>
    <div class="py-12 lg:py-16">
      <div class="max-w-2xl mx-auto space-y-6 mb-16">
        <div class="bg-white rounded-lg overflow-hidden shadow-sm">
          <div class="bg-[#3D2E1C] px-6 py-3">
            <h2 class="text-[#F5C518] font-black uppercase tracking-wide">🐟 Fresh Seafood</h2>
          </div>
          <div class="p-6 space-y-3">
            {["Fish Sandwich", "Fish Tacos", "Shrimp Basket", "Smoked Fish Dip"].map(item => (
              <div class="flex justify-between items-center py-2 border-b border-stone-100 last:border-0">
                <span class="font-medium text-[#3D2E1C]">{item}</span>
                <span class="text-stone-400 text-sm italic">Market price</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-lg overflow-hidden shadow-sm">
          <div class="bg-[#3D2E1C] px-6 py-3">
            <h2 class="text-[#F5C518] font-black uppercase tracking-wide">🥗 Island Flavors</h2>
          </div>
          <div class="p-6 space-y-3">
            {["Poke Bowl", "Maui Bowl", "Conch Fritters"].map(item => (
              <div class="flex justify-between items-center py-2 border-b border-stone-100 last:border-0">
                <span class="font-medium text-[#3D2E1C]">{item}</span>
                <span class="text-stone-400 text-sm italic">Market price</span>
              </div>
            ))}
          </div>
        </div>

        <div class="bg-white rounded-lg overflow-hidden shadow-sm">
          <div class="bg-[#3D2E1C] px-6 py-3">
            <h2 class="text-[#F5C518] font-black uppercase tracking-wide">🥤 Drinks & Sides</h2>
          </div>
          <div class="p-6 space-y-3">
            {["Cold Drinks", "Water & Gatorade", "Snacks & Chips"].map(item => (
              <div class="flex justify-between items-center py-2 border-b border-stone-100 last:border-0">
                <span class="font-medium text-[#3D2E1C]">{item}</span>
                <span class="text-stone-400 text-sm italic">Various</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="bg-[#F5C518] rounded-lg p-6 text-center max-w-2xl mx-auto mb-12">
        <p class="text-[#3D2E1C] font-bold text-sm">
          📋 Menu changes regularly. Follow us on
          <a href="https://www.facebook.com/p/The-Yellow-Bait-House-100057521618227/" target="_blank" class="underline">Facebook</a>
          for daily specials.
        </p>
      </div>

      <div class="bg-[#C41E24] text-white rounded-lg p-8 text-center max-w-2xl mx-auto">
        <h2 class="text-2xl font-black uppercase mb-3">Hungry?</h2>
        <p class="text-red-200 mb-6">Stop by or call ahead.</p>
        <a href="tel:+13054510921" class="inline-block bg-white text-[#C41E24] px-8 py-4 rounded-md font-black text-lg hover:bg-stone-100 transition-colors">
          📞 305-451-0921
        </a>
      </div>
    </div>
  </Container>
</Layout>
