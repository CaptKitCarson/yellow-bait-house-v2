---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout title="Live Cam">
  <div class="bg-[#3D2E1C]">
    <Container>
      <div class="py-10 text-center">
        <div class="flex items-center justify-center gap-3 mb-3">
          <span class="relative flex h-3 w-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-3 w-3 bg-red-500"></span>
          </span>
          <span class="text-xs font-bold text-stone-400 uppercase tracking-widest">Live 24/7</span>
        </div>
        <h1 class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tight">Live Cam</h1>
        <p class="text-stone-400 mt-3">Live from The Yellow Bait House, Key Largo</p>
      </div>
    </Container>
  </div>
  <div class="h-1 bg-[#C41E24]"></div>

  <Container>
    <div class="py-12 lg:py-16">
      <div class="max-w-4xl mx-auto mb-12">
        <div class="bg-stone-900 rounded-lg overflow-hidden shadow-xl aspect-video flex items-center justify-center relative">
          <div class="text-center text-stone-400 p-8">
            <div class="text-6xl mb-4">📹</div>
            <p class="text-2xl font-black text-stone-300 uppercase mb-2">Live Cam</p>
            <p class="text-stone-500">Coming Soon</p>
            <p class="text-stone-600 text-sm mt-4 max-w-md mx-auto">
              We're setting up a 24/7 camera at The Yellow Bait House.
              Check back soon.
            </p>
          </div>
          <!-- WEBCAM EMBED GOES HERE -->
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-between bg-[#3D2E1C] px-6 py-3 text-sm text-stone-400">
          <span>📍 Mile Marker 101, Key Largo FL</span>
          <span>🔄 Auto-refresh</span>
        </div>
      </div>

      <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12">
        <div class="bg-white border-l-4 border-[#F5C518] p-5">
          <h3 class="font-black text-[#3D2E1C] uppercase text-sm">Weather Check</h3>
          <p class="text-stone-500 text-sm mt-1">See real-time conditions before the drive down</p>
        </div>
        <div class="bg-white border-l-4 border-[#F5C518] p-5">
          <h3 class="font-black text-[#3D2E1C] uppercase text-sm">Shop Activity</h3>
          <p class="text-stone-500 text-sm mt-1">Key Largo's busiest bait shop, live</p>
        </div>
        <div class="bg-white border-l-4 border-[#F5C518] p-5">
          <h3 class="font-black text-[#3D2E1C] uppercase text-sm">Keys Vibes</h3>
          <p class="text-stone-500 text-sm mt-1">Florida Keys from anywhere in the world</p>
        </div>
      </div>

      <div class="max-w-4xl mx-auto bg-[#C41E24] text-white rounded-lg p-8 text-center">
        <h2 class="text-xl font-black uppercase mb-3">Like What You See?</h2>
        <p class="text-red-200 mb-6">Come visit. We're open daily from 6AM.</p>
        <a href="/find-us" class="inline-block bg-white text-[#C41E24] px-6 py-3 rounded-md font-black hover:bg-stone-100 transition-colors">
          📍 Get Directions
        </a>
      </div>
    </div>
  </Container>
</Layout>
