---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import storeImg from "@/assets/outside_store_and_sign.webp";
---

<Layout title="Find Us">
  <div class="relative h-64">
    <Image src={storeImg} alt="The Yellow Bait House sign and storefront" class="absolute inset-0 w-full h-full object-cover" width={1600} height={400} />
    <div class="absolute inset-0 bg-gradient-to-r from-[#3D2E1C]/90 to-[#3D2E1C]/50 flex items-end">
      <Container>
        <div class="pb-8">
          <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Visit</span>
          <h1 class="text-4xl lg:text-5xl font-black text-white uppercase tracking-tight">Find Us</h1>
        </div>
      </Container>
    </div>
  </div>

  <Container>
    <div class="py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <!-- Hours -->
          <div class="bg-white rounded-lg overflow-hidden shadow-sm mb-6">
            <div class="bg-[#3D2E1C] px-6 py-3">
              <h2 class="text-[#F5C518] font-black uppercase tracking-wide">Hours & Contact</h2>
            </div>
            <div class="p-6 space-y-4">
              <div class="flex items-start gap-3">
                <span class="text-xl">🕐</span>
                <div>
                  <h3 class="font-bold text-[#3D2E1C]">Hours</h3>
                  <div class="text-stone-600 text-sm space-y-1 mt-1">
                    <p>Monday – Thursday: 6:00 AM – 7:00 PM</p>
                    <p>Friday – Saturday: 6:00 AM – 9:00 PM</p>
                    <p>Sunday: 6:00 AM – 5:00 PM</p>
                  </div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-xl">📞</span>
                <div>
                  <h3 class="font-bold text-[#3D2E1C]">Phone</h3>
                  <a href="tel:+13054510921" class="text-[#C41E24] font-bold text-lg hover:underline">(305) 451-0921</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-xl">📍</span>
                <div>
                  <h3 class="font-bold text-[#3D2E1C]">Address</h3>
                  <p class="text-stone-600">101741 Overseas Hwy<br />Key Largo, FL 33037</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-xl">💳</span>
                <div>
                  <h3 class="font-bold text-[#3D2E1C]">Payment</h3>
                  <p class="text-stone-600 text-sm">Cash, Visa, MasterCard, Amex, Debit</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Directions -->
          <div class="bg-[#F5C518] rounded-lg p-6 mb-6">
            <h2 class="font-black text-[#3D2E1C] uppercase mb-3">🚗 Directions</h2>
            <p class="text-[#5C4A32] leading-relaxed mb-3">
              <strong>Mile Marker 101</strong> on US-1 in Key Largo. Look for the bright yellow building — you literally can't miss it.
            </p>
            <p class="text-[#5C4A32] leading-relaxed mb-3">
              <strong>From Miami:</strong> South on US-1 into Key Largo, we're on your left after the Holiday Inn Express.
            </p>
            <p class="text-[#5C4A32] leading-relaxed">
              <strong>From Islamorada:</strong> North on US-1, we're on your right just past the gas station.
            </p>
          </div>

          <div class="bg-[#3D2E1C] rounded-lg p-5 text-center">
            <p class="text-stone-300 text-sm">🌅 Pro tip: We open at <span class="text-[#F5C518] font-bold">6AM</span> — beat the crowds and get the best bait.</p>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="bg-white rounded-lg overflow-hidden shadow-sm sticky top-8">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3585.5!2d-80.4342!3d25.0864!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d1e0d2f7f3b5e7%3A0x1234567890!2s101741+Overseas+Hwy%2C+Key+Largo%2C+FL+33037!5e0!3m2!1sen!2sus!4v1709000000000!5m2!1sen!2sus"
              width="100%"
              height="400"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full">
            </iframe>
            <div class="p-5">
              <h3 class="font-bold text-[#3D2E1C] mb-2">While You're Here</h3>
              <p class="text-stone-600 text-sm">
                Key Largo has some of the best bridge fishing and reef fishing in the Keys.
                Ask our staff where to go — we'll put you on fish.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Layout>
