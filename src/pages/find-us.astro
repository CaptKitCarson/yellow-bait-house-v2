---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import storeImg from "@/assets/outside_store_and_sign.webp";
---

<Layout title="Find Us">
  <div class="relative">
    <Image src={storeImg} alt="The Yellow Bait House storefront and sign" class="absolute inset-0 w-full h-full object-cover" width={1600} height={600} />
    <div class="absolute inset-0 bg-yellow-800/70"></div>
    <div class="relative">
      <Container>
        <div class="py-16 text-center text-white">
          <h1 class="text-4xl lg:text-5xl font-bold mb-4">Find Us</h1>
          <p class="text-xl text-yellow-200 max-w-2xl mx-auto">
            Right on US-1 in Key Largo. You can't miss the yellow building.
          </p>
        </div>
      </Container>
    </div>
  </div>

  <Container>
    <div class="py-12 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <!-- Hours -->
          <div class="bg-white border border-stone-200 rounded-2xl p-8 mb-8">
            <h2 class="text-2xl font-bold text-yellow-700 mb-6">Hours & Contact</h2>
            <div class="space-y-4">
              <div class="flex items-start gap-3">
                <span class="text-2xl">🕐</span>
                <div>
                  <h3 class="font-bold text-stone-800">Hours</h3>
                  <div class="text-stone-600 text-sm space-y-1 mt-1">
                    <p>Monday – Thursday: 6:00 AM – 7:00 PM</p>
                    <p>Friday – Saturday: 6:00 AM – 9:00 PM</p>
                    <p>Sunday: 6:00 AM – 5:00 PM</p>
                  </div>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-2xl">📞</span>
                <div>
                  <h3 class="font-bold text-stone-800">Phone</h3>
                  <a href="tel:+13054510921" class="text-yellow-700 font-semibold text-lg hover:underline">(305) 451-0921</a>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-2xl">📍</span>
                <div>
                  <h3 class="font-bold text-stone-800">Address</h3>
                  <p class="text-stone-600">
                    101741 Overseas Hwy<br />
                    Key Largo, FL 33037
                  </p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-2xl">💳</span>
                <div>
                  <h3 class="font-bold text-stone-800">Payment</h3>
                  <p class="text-stone-600 text-sm">Cash, Visa, MasterCard, American Express, Debit</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Directions -->
          <div class="bg-yellow-50 border border-yellow-100 rounded-2xl p-8">
            <h2 class="text-2xl font-bold text-yellow-700 mb-4 flex items-center gap-2">
              🚗 Directions
            </h2>
            <p class="text-stone-600 leading-relaxed mb-4">
              We're at <strong>Mile Marker 101</strong> on the Overseas Highway (US-1) in Key Largo.
              Look for the bright yellow building on the ocean side of the road, near the
              intersection with Michele Drive.
            </p>
            <p class="text-stone-600 leading-relaxed mb-4">
              Coming from <strong>Miami/Florida City</strong>: Head south on US-1 into Key Largo.
              We're on your left after you pass the Holiday Inn Express.
            </p>
            <p class="text-stone-600 leading-relaxed">
              Coming from <strong>Islamorada/Lower Keys</strong>: Head north on US-1. We're on
              your right just past the gas station.
            </p>
            <p class="text-stone-500 text-sm mt-4 italic">
              Pro tip: We open at 6AM — beat the crowds and get the best bait selection.
            </p>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="bg-white border border-stone-200 rounded-2xl overflow-hidden sticky top-8">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3585.5!2d-80.4342!3d25.0864!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x88d1e0d2f7f3b5e7%3A0x1234567890!2s101741+Overseas+Hwy%2C+Key+Largo%2C+FL+33037!5e0!3m2!1sen!2sus!4v1709000000000!5m2!1sen!2sus"
              width="100%"
              height="450"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full">
            </iframe>
            <div class="p-6">
              <h3 class="font-bold text-yellow-700 text-lg mb-2">While You're Here</h3>
              <p class="text-stone-600 text-sm">
                Key Largo has some of the best bridge fishing and reef fishing in the Keys.
                Ask our staff where to go — we'll put you on fish.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</Layout>
