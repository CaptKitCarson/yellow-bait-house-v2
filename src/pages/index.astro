---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import heroImg from "@/assets/outside_store.webp";
import storeSignImg from "@/assets/outside_store_and_sign.webp";
import mahisImg from "@/assets/mahiswithsign.jpg";
import lobstersImg from "@/assets/lobsters.jpg";
import baitairImg from "@/assets/baitair.jpg";
import mangrovesImg from "@/assets/mangroves.jpg";
import permitImg from "@/assets/permit.jpg";
---

<Layout title="Key Largo's Favorite Bait Shop & Seafood Market">
  <!-- Hero - split layout, not centered -->
  <div class="bg-[#F5C518]">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[500px]">
        <div class="flex flex-col justify-center px-6 lg:px-16 py-16">
          <span class="text-[#C41E24] text-sm font-bold uppercase tracking-widest mb-3">Mile Marker 101 · Key Largo</span>
          <h1 class="text-5xl lg:text-7xl font-black text-[#3D2E1C] leading-none mb-6">
            THE<br />YELLOW<br />BAIT HOUSE
          </h1>
          <p class="text-[#5C4A32] text-lg max-w-md mb-8 leading-relaxed">
            Live bait. Tackle. Rod repairs. Fresh local seafood. Food menu.
            Everything you need under one bright yellow roof.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="tel:+13054510921" class="bg-[#C41E24] text-white px-6 py-3 rounded-md font-bold hover:bg-red-700 transition-colors">
              📞 305-451-0921
            </a>
            <a href="/find-us" class="bg-[#3D2E1C] text-white px-6 py-3 rounded-md font-bold hover:bg-[#5C4A32] transition-colors">
              📍 Directions
            </a>
          </div>
        </div>
        <div class="relative hidden lg:block">
          <Image src={heroImg} alt="The Yellow Bait House storefront" class="absolute inset-0 w-full h-full object-cover" width={900} height={600} />
        </div>
      </div>
    </div>
  </div>

  <!-- Ticker-style hours bar -->
  <div class="bg-[#C41E24] text-white overflow-hidden">
    <div class="py-3 flex items-center justify-center gap-8 text-sm font-bold uppercase tracking-wider">
      <span>🕐 Open Daily from 6AM</span>
      <span class="text-red-300">★</span>
      <span>📍 101741 Overseas Hwy</span>
      <span class="text-red-300">★</span>
      <span>🔧 Rod Repairs & Rentals</span>
      <span class="text-red-300">★</span>
      <span>🐟 Fresh Local Seafood</span>
    </div>
  </div>

  <!-- What We Got - horizontal scroll cards feel -->
  <Container>
    <div class="py-16 lg:py-20">
      <h2 class="text-3xl font-black text-[#3D2E1C] uppercase tracking-tight mb-2">What We Got</h2>
      <div class="h-1 w-20 bg-[#C41E24] mb-10"></div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Big card - Live Bait -->
        <a href="/bait-and-tackle" class="group relative rounded-xl overflow-hidden h-72">
          <Image src={baitairImg} alt="Yellow Bait House branded bait buckets" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Shop</span>
            <h3 class="text-white text-2xl font-black">LIVE BAIT & TACKLE</h3>
            <p class="text-stone-300 text-sm mt-1">Shrimp, pilchards, pinfish, mullet & full tackle shop →</p>
          </div>
        </a>

        <!-- Big card - Seafood -->
        <a href="/seafood-market" class="group relative rounded-xl overflow-hidden h-72">
          <Image src={lobstersImg} alt="Fresh Florida spiny lobster on ice" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Market</span>
            <h3 class="text-white text-2xl font-black">FRESH LOCAL SEAFOOD</h3>
            <p class="text-stone-300 text-sm mt-1">Stone crab, lobster, fresh fish — locally caught only →</p>
          </div>
        </a>

        <!-- Big card - Food -->
        <a href="/food-menu" class="group relative rounded-xl overflow-hidden h-72">
          <Image src={mangrovesImg} alt="Fresh catch on ice" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Eat</span>
            <h3 class="text-white text-2xl font-black">FOOD MENU</h3>
            <p class="text-stone-300 text-sm mt-1">Fish tacos, poke bowls, island flavors →</p>
          </div>
        </a>

        <!-- Big card - Catches -->
        <a href="/bait-and-tackle" class="group relative rounded-xl overflow-hidden h-72">
          <Image src={mahisImg} alt="Happy anglers with mahi-mahi" class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" width={800} height={500} />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
          <div class="absolute bottom-0 left-0 p-6">
            <span class="text-[#F5C518] text-xs font-bold uppercase tracking-widest">Gear Up</span>
            <h3 class="text-white text-2xl font-black">ROD REPAIRS & RENTALS</h3>
            <p class="text-stone-300 text-sm mt-1">Don't own gear? We'll get you fishing today →</p>
          </div>
        </a>
      </div>
    </div>
  </Container>

  <!-- Why section - dark rustic block -->
  <div class="bg-[#3D2E1C] text-white">
    <Container>
      <div class="py-16 lg:py-20">
        <h2 class="text-3xl font-black uppercase tracking-tight mb-2">Why Everyone Stops Here</h2>
        <div class="h-1 w-20 bg-[#C41E24] mb-10"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="border border-stone-600 rounded-lg p-6">
            <span class="text-[#F5C518] text-3xl font-black block mb-2">137+</span>
            <h3 class="text-white font-bold mb-1">5-Star Reviews</h3>
            <p class="text-stone-400 text-sm">"Best bait and tackle in the Upper Keys"</p>
          </div>
          <div class="border border-stone-600 rounded-lg p-6">
            <span class="text-[#F5C518] text-3xl font-black block mb-2">6AM</span>
            <h3 class="text-white font-bold mb-1">We Open Early</h3>
            <p class="text-stone-400 text-sm">Beat the crowds. Get the best bait. Fish first light.</p>
          </div>
          <div class="border border-stone-600 rounded-lg p-6">
            <span class="text-[#F5C518] text-3xl font-black block mb-2">100%</span>
            <h3 class="text-white font-bold mb-1">Local Seafood</h3>
            <p class="text-stone-400 text-sm">No imports. Only fish caught by Keys fishermen.</p>
          </div>
          <div class="border border-stone-600 rounded-lg p-6">
            <span class="text-[#F5C518] text-3xl font-black block mb-2">MM 101</span>
            <h3 class="text-white font-bold mb-1">Can't Miss It</h3>
            <p class="text-stone-400 text-sm">Bright yellow building right on US-1. You'll see it.</p>
          </div>
        </div>
      </div>
    </Container>
  </div>

  <!-- Customer catch banner -->
  <div class="relative h-80">
    <Image src={permitImg} alt="Angler with permit caught in Key Largo" class="absolute inset-0 w-full h-full object-cover" width={1600} height={500} />
    <div class="absolute inset-0 bg-gradient-to-r from-[#3D2E1C]/90 to-transparent flex items-center">
      <Container>
        <div class="max-w-md">
          <h2 class="text-white text-3xl font-black uppercase mb-3">Gear Up.<br />Get Out There.</h2>
          <p class="text-stone-300 mb-6">Our staff knows what's biting, where, and on what. Stop in before you hit the water.</p>
          <a href="tel:+13054510921" class="inline-block bg-[#C41E24] text-white px-6 py-3 rounded-md font-bold hover:bg-red-700 transition-colors">
            📞 305-451-0921
          </a>
        </div>
      </Container>
    </div>
  </div>
</Layout>
