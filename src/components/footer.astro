---
import Container from "@/components/container.astro";
---

<footer class="bg-yellow-800 text-white mt-20">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12">
      <div>
        <h3 class="text-xl font-bold mb-3 flex items-center gap-2">🎣 The Yellow Bait House</h3>
        <p class="text-yellow-200 text-sm leading-relaxed">
          Key Largo's go-to bait shop, tackle store & seafood market.
          Live bait, rod repairs, rentals, fresh local seafood, and a food menu you won't forget.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-3">Contact</h4>
        <ul class="space-y-2 text-yellow-200 text-sm">
          <li>📍 101741 Overseas Hwy<br />Key Largo, FL 33037</li>
          <li>📞 <a href="tel:+13054510921" class="hover:text-white transition-colors">(305) 451-0921</a></li>
          <li>🕐 Mon–Thu: 6AM–7PM</li>
          <li class="pl-6">Fri–Sat: 6AM–9PM</li>
          <li class="pl-6">Sunday: 6AM–5PM</li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-3">Quick Links</h4>
        <ul class="space-y-2 text-yellow-200 text-sm">
          <li><a href="/bait-and-tackle" class="hover:text-white transition-colors">Bait & Tackle</a></li>
          <li><a href="/seafood-market" class="hover:text-white transition-colors">Seafood Market</a></li>
          <li><a href="/food-menu" class="hover:text-white transition-colors">Food Menu</a></li>
          <li><a href="/find-us" class="hover:text-white transition-colors">Find Us</a></li>
          <li><a href="https://www.facebook.com/p/The-Yellow-Bait-House-100057521618227/" target="_blank" rel="noopener" class="hover:text-white transition-colors">Facebook →</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-yellow-700 py-6 text-center text-yellow-300 text-sm">
      <p>© {new Date().getFullYear()} The Yellow Bait House and Seafood Market. All rights reserved.</p>
    </div>
  </Container>
</footer>
