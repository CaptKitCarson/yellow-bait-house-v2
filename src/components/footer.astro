---
import Container from "@/components/container.astro";
import { Image } from "astro:assets";
import logo from "@/assets/logo.jpg";
---

<footer class="bg-[#3D2E1C] text-white mt-0">
  <!-- Rustic divider -->
  <div class="h-2 bg-[#C41E24]"></div>
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 py-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <Image src={logo} alt="The Yellow Bait House" width={50} height={50} class="rounded-md border-2 border-yellow-400" />
          <h3 class="text-xl font-bold text-[#F5C518]">Yellow Bait House</h3>
        </div>
        <p class="text-stone-400 text-sm leading-relaxed">
          Key Largo's original bait shop, tackle store & seafood market.
          If you're fishing the Upper Keys, this is your first stop.
        </p>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-3 text-[#F5C518] uppercase tracking-wide text-sm">Contact</h4>
        <ul class="space-y-2 text-stone-300 text-sm">
          <li>📍 101741 Overseas Hwy<br />Key Largo, FL 33037</li>
          <li>📞 <a href="tel:+13054510921" class="hover:text-[#F5C518] transition-colors">(305) 451-0921</a></li>
          <li>🕐 Mon–Thu: 6AM–7PM</li>
          <li class="pl-6">Fri–Sat: 6AM–9PM</li>
          <li class="pl-6">Sunday: 6AM–5PM</li>
        </ul>
      </div>
      <div>
        <h4 class="font-bold text-lg mb-3 text-[#F5C518] uppercase tracking-wide text-sm">Explore</h4>
        <ul class="space-y-2 text-stone-300 text-sm">
          <li><a href="/bait-and-tackle" class="hover:text-[#F5C518] transition-colors">Bait & Tackle</a></li>
          <li><a href="/seafood-market" class="hover:text-[#F5C518] transition-colors">Seafood Market</a></li>
          <li><a href="/find-us" class="hover:text-[#F5C518] transition-colors">Find Us</a></li>
          <li><a href="https://www.facebook.com/p/The-Yellow-Bait-House-100057521618227/" target="_blank" rel="noopener" class="hover:text-[#F5C518] transition-colors">Facebook →</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-stone-700 py-6 text-center text-stone-500 text-xs uppercase tracking-wider">
      <p>© {new Date().getFullYear()} The Yellow Bait House and Seafood Market · Key Largo, Florida</p>
    </div>
  </Container>
</footer>
